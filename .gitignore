# This .gitignore file is expanded to the directory where `ign checkout` is executed.
# It is NOT for the ign-template repository itself.

# Swift build artifacts
.build/
.swiftpm/
dist/
release/
*.xcodeproj/
*.xcworkspace/

# Frontend (bun + SolidJS) dependencies and build caches
# Note: frontend/dist/ is covered by the dist/ rule above; the bundled assets
# shipped in the Swift package live under Sources/AppCore/Resources/Web/ and are
# tracked intentionally. frontend/bun.lock is the lockfile and is tracked.
node_modules/
.vite/
*.tsbuildinfo
frontend/.bun/

# Nix and local environment files
.pre-commit-config.yaml
result
result-*
**/.direnv
**/.env
**/.envrc.private*
**/*.private*

# IDE and OS metadata
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Temporary files and logs
tmp/
temp/
.cache/
logs/
*.log
deploy/emulation/.runtime/
